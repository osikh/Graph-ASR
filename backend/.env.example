# ── LLM Provider ─────────────────────────────────────────────
LLM_PROVIDER=lmstudio          # lmstudio | llamacpp | openrouter
LLM_MODEL=local-model          # model name served by the provider
LLM_API_KEY=                   # blank for lmstudio/llamacpp; sk-or-v1-... for openrouter
LLM_API_BASE=                  # optional URL override

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://ars:ars@localhost:5432/ars

# ── Neo4j ─────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
