# ── LLM ──────────────────────────────────────────────
# Set the model you want to use. LiteLLM handles the rest.
# Examples:
#   openai/gpt-4o
#   anthropic/claude-sonnet-4-6
#   ollama/llama3.1
#   lm_studio/local-model
LLM_MODEL=openai/gpt-4o-mini
LLM_API_KEY=sk-...          # leave empty for Ollama / LM Studio
LLM_API_BASE=               # e.g. http://localhost:11434 for Ollama

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://ars:ars@localhost:5432/ars

# ── Neo4j ─────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── App ───────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
